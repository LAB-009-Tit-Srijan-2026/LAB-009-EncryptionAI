# --- AI API Keys ---
# Get your Gemini key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Get your Amadeus keys at: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Get your Google Places key at: https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# --- Database Configuration ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=travel_ai
DB_USER=root
DB_PASSWORD=your_mysql_password

# --- Security ---
# Generate a secure key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_jwt_key_here
